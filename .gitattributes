# Normalize line endings to LF (Unix style) for all files in the repository
# This ensures consistency across Windows, Mac, and Linux developers

# Python files
*.py text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Configuration files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.sql text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files (don't convert)
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.tar binary
*.gz binary
